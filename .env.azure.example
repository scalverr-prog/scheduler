# Azure Patient Scheduler Environment Variables
# Copy this file to .env.azure and fill in your values

# ===========================================
# Database Configuration (Azure PostgreSQL)
# ===========================================
# Format: postgresql://username:password@server.postgres.database.azure.com:5432/database?sslmode=require
DATABASE_URL=postgresql://psqladmin:YOUR_PASSWORD@psql-patient-scheduler.postgres.database.azure.com:5432/scheduler?sslmode=require

# Flag to enable Azure-specific database configuration
AZURE_POSTGRESQL=true

# ===========================================
# Authentication & Security
# ===========================================
# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-secure-jwt-secret-here

# OAuth configuration (keep from existing setup)
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=your-owner-open-id

# ===========================================
# AI Features (Voice Scribe)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ===========================================
# Azure-Specific Settings
# ===========================================
NODE_ENV=production
PORT=3000

# Key Vault URI (if using Azure Key Vault for secrets)
# AZURE_KEY_VAULT_URI=https://kv-patient-scheduler.vault.azure.net/

# ===========================================
# Optional: Azure AD Authentication
# ===========================================
# Uncomment if switching to Azure AD for authentication
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret

# ===========================================
# HIPAA Compliance Notes
# ===========================================
# 1. Never commit this file with real values
# 2. Use Azure Key Vault for production secrets
# 3. Ensure SSL is always enabled (sslmode=require)
# 4. Enable audit logging in Azure
# 5. Sign Microsoft BAA before storing PHI
